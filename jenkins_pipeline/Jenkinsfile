pipeline {
    agent any

    environment {
        // Fix "docker: command not found" by including Mac Docker paths
        PATH = "/usr/local/bin:/opt/homebrew/bin:${env.PATH}"
        
        // Global Variables
        DOCKER_REGISTRY = 'your-registry.com/placement-intelligence'
        FRONTEND_IMAGE = "${DOCKER_REGISTRY}/frontend"
        BACKEND_IMAGE = "${DOCKER_REGISTRY}/backend"
        AGENT_IMAGE = "${DOCKER_REGISTRY}/agent"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '5'))
        timeout(time: 30, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        stage('Preparation') {
            steps {
                echo "Running directly in project workspace!"
                
                // Ensure scripts are executable
                sh 'chmod +x jenkins_pipeline/scripts/*.sh'

                // Load .env files securely from Jenkins Credentials
                withCredentials([file(credentialsId: 'BACKEND_ENV_FILE', variable: 'BACKEND_ENV')]) {
                    sh 'cp $BACKEND_ENV .env'
                }
                withCredentials([file(credentialsId: 'FRONTEND_ENV_FILE', variable: 'FRONTEND_ENV')]) {
                    sh 'cp $FRONTEND_ENV frontend/.env'
                }
            }
        }

        stage('Unit Testing') {
            parallel {
                stage('Backend Tests') {
                    steps {
                        echo "Running Backend Python Tests (Simulated)..."
                        sh 'echo "Backend tests passed successfully."'
                    }
                }
                stage('Frontend Tests') {
                    steps {
                        echo "Running Frontend React Tests (Simulated)..."
                        sh 'echo "Frontend tests passed successfully."'
                    }
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                echo "Building Backend Image..."
                sh "docker build -t ${BACKEND_IMAGE}:latest -f backend/Dockerfile backend/"
                
                echo "Building Agent Image..."
                sh "docker build -t ${AGENT_IMAGE}:latest -f intelligence_pipeline/Dockerfile intelligence_pipeline/"
                
                echo "Building Frontend Image..."
                sh "docker build -t ${FRONTEND_IMAGE}:latest -f frontend/Dockerfile frontend/"
            }
        }

        stage('Deployment') {
            steps {
                script {
                    def ENV = 'production'
                    echo "Deploying to ${ENV}..."
                    // Call the deployment script
                    sh "./jenkins_pipeline/scripts/deploy.sh ${ENV} latest"
                }
            }
        }

        stage('Health Checks') {
            steps {
                script {
                    def ENV = 'production'
                    echo "Running Health Checks on ${ENV}..."
                    // Call the health check script
                    sh "./jenkins_pipeline/scripts/health-check.sh ${ENV}"
                }
            }
        }
    }

    post {
        success {
            echo "✅ Pipeline succeeded! The application has been deployed successfully."
        }
        failure {
            script {
                echo "🚨 Pipeline failed! Initiating Rollback..."
                sh "export PREVIOUS_COMMIT=latest && ./jenkins_pipeline/scripts/rollback.sh production || true"
            }
        }
        always {
            script {
                echo "Cleaning up local docker images to save space..."
                sh "docker image prune -f || true"
            }
        }
    }
}
